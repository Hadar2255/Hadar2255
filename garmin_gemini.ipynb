   "source": [
    "# ======================================================\n",
    "# 🔑 פרטי Garmin Connect\n",
    "GARMIN_EMAIL    = \"your@email.com\"       # ← שנה לאימייל שלך\n",
    "GARMIN_PASSWORD = \"your-password\"        # ← שנה לסיסמה שלך\n",
    "\n",
    "# 🤖 מפתח Gemini AI (חינמי מ-aistudio.google.com)\n",
    "GEMINI_API_KEY  = \"your-gemini-api-key\" # ← הדבק את המפתח שלך\n",
    "\n",
    "# 🌐 GitHub (לשמירת ניתוחים באתר)\n",
    "GITHUB_TOKEN    = \"ghp_your_token_here\" # ← הדבק את ה-token\n",
    "GITHUB_REPO     = \"Hadar2255/Hadar2255\" # ← שם-משתמש/שם-ריפוזיטורי\n",
    "\n",
    "# ⚙️ הגדרות ניתוח\n",
    "DAYS_BACK       = 14    # כמה ימים אחורה לנתח\n",
    "MAX_ACTIVITIES  = 10    # מקסימום פעילויות לניתוח ביומכניקה\n",
    "# ======================================================\n",
    "\n",
    "print('✅ הגדרות נשמרו!')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step3-title",
   "metadata": {},
   "source": [
    "## שלב 3: שליפת נתוני Garmin\n",
    "*מתחבר לחשבונך ושולף פעילויות, בריאות, ביומכניקה...*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fetch-garmin",
   "metadata": {},
   "outputs": [],
   "source": [
    "import garminconnect\n",
    "from datetime import date, timedelta\n",
    "import json\n",
    "import io\n",
    "\n",
    "try:\n",
    "    from fitparse import FitFile\n",
    "    HAS_FITPARSE = True\n",
    "except ImportError:\n",
    "    HAS_FITPARSE = False\n",
    "\n",
    "# --- חיבור לגרמין ---\n",
    "print('🔗 מתחבר ל-Garmin Connect...')\n",
    "garmin = garminconnect.Garmin(GARMIN_EMAIL, GARMIN_PASSWORD)\n",
    "garmin.login()\n",
    "print('✅ מחובר!')\n",
    "\n",
    "# --- תאריכים ---\n",
    "today      = date.today()\n",
    "start_date = today - timedelta(days=DAYS_BACK)\n",
    "last_7     = [today - timedelta(days=i) for i in range(7)]\n",
    "\n",
    "# --- פעילויות ריצה ---\n",
    "print(f'📊 שולף פעילויות מ-{start_date} עד {today}...')\n",
    "try:\n",
    "    activities = garmin.get_activities_by_date(\n",
    "        str(start_date), str(today), \"running\"\n",
    "    )\n",
    "except Exception:\n",
    "    activities = garmin.get_activities(0, 20)\n",
    "    activities = [a for a in activities if a.get('activityType', {}).get('typeKey') in ('running', 'trail_running', 'treadmill_running')]\n",
    "\n",
    "print(f'✅ נמצאו {len(activities)} פעילויות ריצה')\n",
    "\n",
    "# --- שינה ---\n",
    "print('😴 שולף נתוני שינה...')\n",
    "sleep_data = []\n",
    "for d in last_7:\n",
    "    try:\n",
    "        s = garmin.get_sleep_data(str(d))\n",
    "        if s:\n",
    "            daily = s.get('dailySleepDTO', {})\n",
    "            sleep_data.append({\n",
    "                'date': str(d),\n",
    "                'duration_hours': round(daily.get('sleepTimeSeconds', 0) / 3600, 1),\n",
    "                'deep_sleep_hours': round(daily.get('deepSleepSeconds', 0) / 3600, 1),\n",
    "                'rem_sleep_hours': round(daily.get('remSleepSeconds', 0) / 3600, 1),\n",
    "                'score': daily.get('sleepScores', {}).get('overall', {}).get('value', 'N/A')\n",
    "            })\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "# --- HRV ---\n",
    "print('❤️ שולף נתוני HRV...')\n",
    "hrv_data = []\n",
    "for d in last_7:\n",
    "    try:\n",
    "        h = garmin.get_hrv_data(str(d))\n",
    "        if h and h.get('hrvSummary'):\n",
    "            hrv_data.append({\n",
    "                'date': str(d),\n",
    "                'weekly_avg': h['hrvSummary'].get('weeklyAvg'),\n",
    "                'last_night': h['hrvSummary'].get('lastNight'),\n",
    "                'status': h['hrvSummary'].get('status')\n",
    "            })\n",
    "    except Exception:\n",
    "        pass\n",
    "\n",
    "# --- Training Status ---\n",
    "print('🏋️ שולף סטטוס אימון...')\n",
    "training_status = {}\n",
    "try:\n",
    "    ts = garmin.get_training_status(str(today))\n",
    "    if ts:\n",
    "        training_status = ts\n",
    "except Exception:\n",
    "    pass\n",
    "\n",
    "# --- ביומכניקה מ-FIT files ---\n",
    "print(f'🦿 שולף ביומכניקה מ-{min(len(activities), MAX_ACTIVITIES)} אימונים...')\n",
    "biomechanics_list = []\n",
    "\n",
    "for activity in activities[:MAX_ACTIVITIES]:\n",
    "    act_id = activity.get('activityId')\n",
    "    bio = {\n",
    "        'date': activity.get('startTimeLocal', '')[:10],\n",
    "        'name': activity.get('activityName', 'ריצה'),\n",
    "        'distance_km': round(activity.get('distance', 0) / 1000, 2),\n",
    "        'duration_min': round(activity.get('duration', 0) / 60, 1),\n",
    "        'avg_hr': activity.get('averageHR'),\n",
    "        'max_hr': activity.get('maxHR'),\n",
    "        'avg_cadence': activity.get('averageRunningCadenceInStepsPerMinute'),\n",
    "        'max_cadence': activity.get('maxRunningCadenceInStepsPerMinute'),\n",
    "        'avg_power': activity.get('avgPower'),\n",
    "        'normalized_power': activity.get('normPower'),\n",
    "        'aerobic_te': activity.get('aerobicTrainingEffect'),\n",
    "        'anaerobic_te': activity.get('anaerobicTrainingEffect'),\n",
    "        'training_load': activity.get('activityTrainingLoad'),\n",
    "        'training_effect_label': activity.get('trainingEffectLabel'),\n",
    "        'avg_speed_kmh': round(activity.get('averageSpeed', 0) * 3.6, 2) if activity.get('averageSpeed') else None,\n",
    "        'elevation_gain': activity.get('elevationGain'),\n",
    "        # FIT-level dynamics (filled below)\n",
    "        'avg_gct_ms': None,\n",
    "        'avg_vertical_oscillation_cm': None,\n",
    "        'avg_vertical_ratio': None,\n",
    "        'avg_ground_contact_balance': None,\n",
    "        'avg_stride_length_m': None,\n",
    "    }\n",
    "\n",
    "    # Try FIT file for granular biomechanics\n",
    "    if HAS_FITPARSE and act_id:\n",
    "        try:\n",
    "            fit_bytes = garmin.download_activity(\n",
    "                act_id, dl_fmt=garminconnect.Garmin.ActivityDownloadFormat.ORIGINAL\n",
    "            )\n",
    "            fitfile = FitFile(io.BytesIO(fit_bytes))\n",
    "            gct_vals, vert_osc_vals, vert_ratio_vals, gcb_vals, stride_vals = [], [], [], [], []\n",
    "            for record in fitfile.get_messages('record'):\n",
    "                data = {f.name: f.value for f in record}\n",
    "                if data.get('stance_time'):        gct_vals.append(data['stance_time'])\n",
    "                if data.get('vertical_oscillation'): vert_osc_vals.append(data['vertical_oscillation'])\n",
    "                if data.get('vertical_ratio'):      vert_ratio_vals.append(data['vertical_ratio'])\n",
    "                if data.get('stance_time_balance'): gcb_vals.append(data['stance_time_balance'])\n",
    "                if data.get('step_length'):         stride_vals.append(data['step_length'])\n",
    "            if gct_vals:       bio['avg_gct_ms'] = round(sum(gct_vals) / len(gct_vals), 1)\n",
    "            if vert_osc_vals:  bio['avg_vertical_oscillation_cm'] = round(sum(vert_osc_vals) / len(vert_osc_vals) / 10, 1)\n",
    "            if vert_ratio_vals:bio['avg_vertical_ratio'] = round(sum(vert_ratio_vals) / len(vert_ratio_vals), 1)\n",
    "            if gcb_vals:       bio['avg_ground_contact_balance'] = round(sum(gcb_vals) / len(gcb_vals), 1)\n",
    "            if stride_vals:    bio['avg_stride_length_m'] = round(sum(stride_vals) / len(stride_vals) / 1000, 2)\n",
    "        except Exception:\n",
    "            pass\n",
    "\n",
    "    biomechanics_list.append(bio)\n",
    "\n",
    "print(f'✅ ביומכניקה נשלפה!')\n",
    "\n",
    "# --- סיכום ---\n",
    "cadence_vals = [b['avg_cadence'] for b in biomechanics_list if b['avg_cadence']]\n",
    "gct_vals_all = [b['avg_gct_ms'] for b in biomechanics_list if b['avg_gct_ms']]\n",
    "vo_vals      = [b['avg_vertical_oscillation_cm'] for b in biomechanics_list if b['avg_vertical_oscillation_cm']]\n",
    "avg_cadence  = round(sum(cadence_vals)/len(cadence_vals), 1) if cadence_vals else 'N/A'\n",
    "avg_gct      = round(sum(gct_vals_all)/len(gct_vals_all), 1) if gct_vals_all else 'N/A'\n",
    "avg_vert_osc = round(sum(vo_vals)/len(vo_vals), 1) if vo_vals else 'N/A'\n",
    "\n",
    "print(f'''\n",
    "📈 סיכום נתונים:\n",
    "   פעילויות ריצה: {len(activities)}\n",
    "   קידוד ממוצע:   {avg_cadence} spm\n",
    "   GCT ממוצע:     {avg_gct} ms\n",
    "   תנודה אנכית:   {avg_vert_osc} cm\n",
    "   נתוני שינה:    {len(sleep_data)} ימים\n",
    "   נתוני HRV:     {len(hrv_data)} ימים\n",
    "''')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "step4-title",
   "metadata": {},
   "source": [
    "## שלב 4: שליחת נתונים ל-Gemini AI\n",
    "*הבינה המלאכותית תנתח את הנתונים ותצור תוכנית...*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "gemini-analysis",
   "metadata": {},
   "outputs": [],
   "source": [
    "import google.genai as genai\n",
    "\n",
    "client = genai.Client(api_key=GEMINI_API_KEY)\n",
    "\n",
    "# --- בניית סיכום פעילויות ---\n",
    "activities_text = \"\"\n",
    "for b in biomechanics_list:\n",
    "    activities_text += f\"\"\"\n",
    "  • {b['date']} - {b['name']}\n",
    "    מרחק: {b['distance_km']} ק\"מ | זמן: {b['duration_min']} דק' | קצב: {b['avg_speed_kmh']} קמ\"ש\n",
    "    דופק ממוצע: {b['avg_hr']} | דופק מקסימלי: {b['max_hr']}\n",
    "    קידוד: {b['avg_cadence']} spm | עוצמה: {b['avg_power']} W\n",
    "    Training Effect: אירובי {b['aerobic_te']} | אנאירובי {b['anaerobic_te']} ({b['training_effect_label']})\n",
    "    עומס אימון: {b['training_load']}\"\"\"\n",
    "    if b['avg_gct_ms']:       activities_text += f\"\\n    זמן מגע קרקע: {b['avg_gct_ms']} ms\"\n",
    "    if b['avg_vertical_oscillation_cm']: activities_text += f\" | תנודה אנכית: {b['avg_vertical_oscillation_cm']} cm\"\n",
    "    if b['avg_vertical_ratio']: activities_text += f\" | יחס אנכי: {b['avg_vertical_ratio']}%\"\n",
    "    if b['avg_ground_contact_balance']: activities_text += f\" | איזון: {b['avg_ground_contact_balance']}%\"\n",
    "    if b['avg_stride_length_m']: activities_text += f\" | אורך צעד: {b['avg_stride_length_m']} m\"\n",
    "\n",
    "# --- סיכום שינה ---\n",
    "sleep_text = \"\"\n",
    "for s in sleep_data:\n",
    "    sleep_text += f\"\\n  • {s['date']}: {s['duration_hours']} שעות (עמוק: {s['deep_sleep_hours']}h, REM: {s['rem_sleep_hours']}h, ציון: {s['score']})\"\n",
    "\n",
    "# --- סיכום HRV ---\n",
    "hrv_text = \"\"\n",
    "for h in hrv_data:\n",
    "    hrv_text += f\"\\n  • {h['date']}: לאחרון {h['last_night']} ms | ממוצע שבועי {h['weekly_avg']} ms | סטטוס: {h['status']}\"\n",
    "\n",
    "# --- הפרומפט לג'מיני ---\n",
    "prompt = f\"\"\"אתה מאמן ריצה מקצועי ומומחה לביומכניקה. הנה נתוני הספורטאי שלי מ-{DAYS_BACK} הימים האחרונים:\n",
    "\n",
    "## פעילויות ריצה:\n",
    "{activities_text}\n",
    "\n",
    "## נתוני שינה (7 ימים אחרונים):\n",
    "{sleep_text if sleep_text else '  לא זמין'}\n",
    "\n",
    "## נתוני HRV (7 ימים אחרונים):\n",
    "{hrv_text if hrv_text else '  לא זמין'}\n",
    "\n",
    "## ממוצעי ביומכניקה:\n",
    "  קידוד ממוצע: {avg_cadence} spm (מטרה: 170-180)\n",
    "  זמן מגע עם הקרקע (GCT): {avg_gct} ms (מטרה: 200-270 ms)\n",
    "  תנודה אנכית: {avg_vert_osc} cm (מטרה: 6-8 cm)\n",
    "\n",
    "---\n",
    "אנא ספק לי:\n",
    "\n",
    "## 1. ניתוח ביומכניקה 🦿\n",
    "- האם הקידוד שלי אופטימלי? מה לשפר?\n",
    "- ניתוח GCT - האם אני מבלה יותר מדי זמן על הקרקע?\n",
    "- ניתוח תנודה אנכית - האם אני \"מבזבז\" אנרגיה כלפי מעלה?\n",
    "- מה המשמעות של האיזון שמאל/ימין?\n",
    "\n",
    "## 2. ניתוח עומס אימון ✅\n",
    "- האם נפח האימון מתאים לרמתי?\n",
    "- ניתוח יחס עומס קל/קשה\n",
    "- מצב התאוששות לפי HRV ושינה\n",
    "- מה Training Effect אומר על האימונים שלי?\n",
    "\n",
    "## 3. תוכנית אימון שבועית 📅\n",
    "צור תוכנית ל-7 הימים הבאים עם 3-5 ריצות:\n",
    "לכל ריצה ציין:\n",
    "  - יום ואופי הריצה (קל/טמפו/מרווחים/ארוכה)\n",
    "  - מרחק ומשך זמן\n",
    "  - אזור דופק מטרה (1-5)\n",
    "  - קצב מטרה (דק'/ק\"מ)\n",
    "  - הנחיות ביומכניקה ספציפיות לאותה ריצה\n",
    "\n",
    "## 4. תרגילי שיפור ביומכניקה 💪\n",
    "3-5 תרגילים ספציפיים לשיפור החולשות שזיהית, עם הסבר איך לבצע.\n",
    "\n",
    "ענה בעברית. היה ספציפי עם מספרים ומדדים. אל תהיה גנרי.\n",
    "\"\"\"\n",
    "\n",
    "print('🤖 שולח נתונים ל-Gemini AI... (יכול לקחת 30-60 שניות)')\n",
    "response = client.models.generate_content(\n",
    "    model=\"gemini-2.0-flash\",\n",
    "    contents=prompt\n",
    ")\n",
    "gemini_analysis = response.text\n",
    "print('✅ ניתוח התקבל!')"
   ]
  },
