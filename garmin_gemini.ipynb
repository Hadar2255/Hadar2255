    "## שלב 7: שמירת הניתוח באתר 🌐\n",
    "*הנתונים יישמרו ב-GitHub ויופיעו באתר האישי שלך*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "save-to-github",
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "import base64\n",
    "\n",
    "GITHUB_API = \"https://api.github.com\"\n",
    "headers = {\n",
    "    \"Authorization\": f\"Bearer {GITHUB_TOKEN}\",\n",
    "    \"Accept\": \"application/vnd.github+json\",\n",
    "    \"X-GitHub-Api-Version\": \"2022-11-28\"\n",
    "}\n",
    "\n",
    "def push_to_github(filename, content_dict):\n",
    "    \"\"\"שמור קובץ JSON ל-GitHub.\"\"\"\n",
    "    content_str = json.dumps(content_dict, ensure_ascii=False, indent=2)\n",
    "    content_b64 = base64.b64encode(content_str.encode('utf-8')).decode('ascii')\n",
    "\n",
    "    url = f\"{GITHUB_API}/repos/{GITHUB_REPO}/contents/{filename}\"\n",
    "\n",
    "    # Check if file exists (to get SHA for update)\n",
    "    sha = None\n",
    "    r = requests.get(url, headers=headers)\n",
    "    if r.status_code == 200:\n",
    "        sha = r.json().get('sha')\n",
    "\n",
    "    payload = {\n",
    "        \"message\": f\"ניתוח גרמין - {today}\",\n",
    "        \"content\": content_b64,\n",
    "        \"branch\": \"main\"\n",
    "    }\n",
    "    if sha:\n",
    "        payload[\"sha\"] = sha\n",
    "\n",
    "    r = requests.put(url, headers=headers, json=payload)\n",
    "    return r.status_code in (200, 201)\n",
    "\n",
    "# --- בניית נתוני הניתוח ---\n",
    "analysis_record = {\n",
    "    \"date\": str(today),\n",
    "    \"summary\": {\n",
    "        \"total_runs\": len(activities),\n",
    "        \"avg_cadence\": avg_cadence,\n",
    "        \"avg_gct_ms\": avg_gct,\n",
    "        \"avg_vertical_oscillation_cm\": avg_vert_osc\n",
    "    },\n",
    "    \"activities\": biomechanics_list,\n",
    "    \"sleep\": sleep_data,\n",
    "    \"hrv\": hrv_data,\n",
    "    \"gemini_analysis\": gemini_analysis,\n",
    "    \"created_workouts\": created_workouts\n",
    "}\n",
    "\n",
    "print('📤 שומר נתונים ב-GitHub...')\n",
    "\n",
    "# שמור את הניתוח הנוכחי\n",
    "ok1 = push_to_github(f\"data/{today}.json\", analysis_record)\n",
    "# עדכן latest.json\n",
    "ok2 = push_to_github(\"data/latest.json\", analysis_record)\n",
    "\n",
    "# שמור/עדכן index של כל הניתוחים\n",
    "index_url = f\"{GITHUB_API}/repos/{GITHUB_REPO}/contents/data/index.json\"\n",
    "r = requests.get(index_url, headers=headers)\n",
    "if r.status_code == 200:\n",
    "    existing_index = json.loads(base64.b64decode(r.json()['content']).decode('utf-8'))\n",
    "else:\n",
    "    existing_index = []\n",
    "\n",
    "entry = {\"date\": str(today), \"file\": f\"data/{today}.json\",\n",
    "         \"runs\": len(activities), \"avg_cadence\": avg_cadence}\n",
    "existing_index = [e for e in existing_index if e.get('date') != str(today)]\n",
    "existing_index.append(entry)\n",
    "existing_index.sort(key=lambda x: x['date'], reverse=True)\n",
    "ok3 = push_to_github(\"data/index.json\", existing_index)\n",
    "\n",
    "if ok1 and ok2 and ok3:\n",
    "    print(f'✅ נשמר בהצלחה!')\n",
    "    print(f'\\n🌐 האתר שלך: https://hadar2255.github.io/Hadar2255')\n",
    "else:\n",
    "    print('⚠️ בעיה בשמירה ל-GitHub. בדוק שה-Token שלך תקף.')\n",
    "\n",
    "print('\\n' + '='*50)\n",
    "print('🎉 הכל הושלם!')\n",
    "print('='*50)\n",
    "print(f'✅ נותחו {len(activities)} ריצות')\n",
    "print(f'✅ נוצרו {len(created_workouts)} אימונים לשבוע הבא')\n",
    "print(f'✅ הניתוח נשמר באתר')\n",
    "print()\n",
    "print('📱 הצעד הבא: פתח אפליקציית Garmin Connect וסנכרן עם השעון')"
   ]
  }
