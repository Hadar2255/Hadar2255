   "source": [
    "## שלב 6: יצירת אימונים בגרמין 🏃\n",
    "*האימונים ייוצרו ב-Garmin Connect ויגיעו לשעון דרך סנכרון*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "create-workouts",
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- פרסור תוכנית האימון מתשובת ג'מיני ---\n",
    "# שולחים בקשה ממוקדת לג'מיני להפיק JSON עם פרטי האימונים\n",
    "\n",
    "workout_prompt = f\"\"\"בהתבסס על הניתוח הזה:\n",
    "{gemini_analysis}\n",
    "\n",
    "הפק JSON בלבד (ללא הסברים) עם מערך של אימונים לשבוע הבא.\n",
    "פורמט:\n",
    "[\n",
    "  {{\n",
    "    \"name\": \"שם האימון בעברית\",\n",
    "    \"type\": \"easy|tempo|intervals|long\",\n",
    "    \"day_offset\": 1,\n",
    "    \"warmup_minutes\": 10,\n",
    "    \"main_minutes\": 30,\n",
    "    \"cooldown_minutes\": 10,\n",
    "    \"target_hr_zone\": 2,\n",
    "    \"description\": \"תיאור קצר בעברית\"\n",
    "  }}\n",
    "]\n",
    "day_offset: 1=מחר, 2=מחרתיים וכו'. עד 5 אימונים.\"\"\"\n",
    "\n",
    "workout_response = client.models.generate_content(\n",
    "    model=\"gemini-2.0-flash\",\n",
    "    contents=workout_prompt\n",
