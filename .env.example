# איזה ספק AI להשתמש: groq (מומלץ - חינמי וגמיש) או gemini.
# אם תגדיר GROQ_API_KEY ושום AI_PROVIDER, ייבחר groq אוטומטית.
AI_PROVIDER=groq

# *** Groq (מומלץ) ***
# מפתח חינמי מ-https://console.groq.com
# מגבלה חינמית: ~14,400 בקשות ביום (פי 700 מ-Gemini החינמי).
GROQ_API_KEY=
# מודל ברירת מחדל: llama-3.3-70b-versatile (חכם, עברית טובה, function calling)
GROQ_MODEL=llama-3.3-70b-versatile

# *** Gemini (אופציה אלטרנטיבית, מוגבל ל-20 בקשות ביום בחינם) ***
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# שם הבוט בקבוצה
BOT_NAME=ויקטור

# מיקום מסד הנתונים המקומי
# ב-Railway: הגדר ל- /persist/bot.db (ב-Volume)
DB_PATH=./data/bot.db

# מיקום תיקיית אישורי וואטסאפ
# ב-Railway: הגדר ל- /persist/auth_info (ב-Volume)
AUTH_INFO_PATH=./auth_info

# *** אבטחה - מומלץ בחום ***
# סיסמה (לפחות 12 תווים) שמצפינה את כל ההודעות והרשימות.
BOT_ENCRYPTION_KEY=

# מצב פרטי: כשמופעל (=1), לא נשלחת היסטוריה ל-AI.
BOT_PRIVATE_MODE=0
