# Garmin Connect credentials
GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# Anthropic API key - get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: how many weeks of history to analyze (default: 4)
WEEKS_HISTORY=4

# Optional: your fitness goals (running, cycling, triathlon, strength, weight_loss, general)
FITNESS_GOAL=general

# Optional: your name for personalized output
USER_NAME=Hadar
