# מפתח Gemini API מ-https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# שם הבוט בקבוצה
BOT_NAME=ויקטור

# מודל Gemini (flash מהיר וזול, pro חכם יותר)
GEMINI_MODEL=gemini-2.5-flash

# מיקום מסד הנתונים המקומי
DB_PATH=./data/bot.db

# *** אבטחה — מומלץ בחום ***
# סיסמה (לפחות 12 תווים) שמצפינה את כל ההודעות והרשימות בקובץ DB.
# בלי המפתח הזה, מי שיש לו גישה לקובץ DB יכול לקרוא הכל.
# לדוגמה ייצור: openssl rand -base64 32  (Mac/Linux)
BOT_ENCRYPTION_KEY=

# מצב פרטי: כשמופעל (=1), לא נשלחת היסטוריית הקבוצה ל-Gemini.
# רק ההודעה הספציפית שפנתה לבוט תישלח. הבוט יאבד יכולת "להעלות" דברים
# שנאמרו בקבוצה אבל לא בפנייה ישירה אליו.
BOT_PRIVATE_MODE=0
